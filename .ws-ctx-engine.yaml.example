# ws-ctx-engine Configuration Example
# Copy this file to .ws-ctx-engine.yaml in your repository root and customize as needed

# ==============================================================================
# OUTPUT SETTINGS
# ==============================================================================

# Output format for generated context packs
# Options: "xml" | "zip"
# - xml: Single file with Repomix-style structure (for paste workflows)
# - zip: Archive with preserved directory structure + manifest (for upload workflows)
format: zip

# Maximum token budget for LLM context window
# The system reserves 20% for metadata, using 80% for actual file content
# Common values:
#   - Claude 3.5 Sonnet: 200000
#   - GPT-4 Turbo: 128000
#   - GPT-4: 8192
#   - Claude 2: 100000
token_budget: 100000

# Output directory for generated context packs
# Relative paths are resolved from repository root
output_path: ./output

# ==============================================================================
# SCORING WEIGHTS
# ==============================================================================

# Weight for semantic similarity score (0.0 to 1.0)
# Higher values prioritize files matching the query semantically
# Recommended: 0.6 for query-driven workflows
semantic_weight: 0.6

# Weight for PageRank structural importance score (0.0 to 1.0)
# Higher values prioritize core dependencies and central files
# Recommended: 0.4 for balanced ranking
# Note: semantic_weight + pagerank_weight should equal 1.0
pagerank_weight: 0.4

# ==============================================================================
# FILE FILTERING
# ==============================================================================

# Include test files in the context pack
# Set to true if you want test files included in the output
include_tests: false

# Respect .gitignore automatically when indexing/searching
# Set to false only when you explicitly want ignored files indexed
respect_gitignore: true

# Glob patterns for files to include
# Uses Python glob syntax with ** for recursive matching
include_patterns:
  - "**/*.py"          # Python files
  - "**/*.js"          # JavaScript files
  - "**/*.ts"          # TypeScript files
  - "**/*.tsx"         # TypeScript React files
  - "**/*.jsx"         # JavaScript React files
  - "**/*.java"        # Java files
  - "**/*.cs"          # C# files
  - "**/*.go"          # Go files
  - "**/*.rs"          # Rust files
  - "**/*.cpp"         # C++ files
  - "**/*.c"           # C files
  - "**/*.h"           # Header files
  - "**/*.rb"          # Ruby files
  - "**/*.php"         # PHP files
  - "**/*.swift"       # Swift files
  - "**/*.kt"          # Kotlin files
  - "**/*.scala"       # Scala files

# Glob patterns for files to exclude
# These patterns override include_patterns
exclude_patterns:
  - "*.min.js"         # Minified JavaScript
  - "*.min.css"        # Minified CSS
  - "node_modules/**"  # Node.js dependencies
  - "__pycache__/**"   # Python bytecode cache
  - ".git/**"          # Git repository data
  - ".svn/**"          # SVN repository data
  - "venv/**"          # Python virtual environment
  - "env/**"           # Python virtual environment
  - ".venv/**"         # Python virtual environment
  - "dist/**"          # Build output
  - "build/**"         # Build output
  - "target/**"        # Build output (Rust, Java)
  - "*.pyc"            # Python bytecode
  - "*.pyo"            # Python optimized bytecode
  - "*.so"             # Shared objects
  - "*.dylib"          # Dynamic libraries
  - "*.dll"            # Windows DLLs
  - ".DS_Store"        # macOS metadata
  - "Thumbs.db"        # Windows thumbnails
  - ".ws-ctx-engine/**" # ws-ctx-engine index/log artifacts
  - ".ws-ctx-engine.yaml" # ws-ctx-engine config file

# ==============================================================================
# BACKEND SELECTION
# ==============================================================================

backends:
  # Vector index backend for semantic search
  # Options: "auto" | "native-leann" | "leann" | "faiss"
  # - auto: Try NativeLEANN first (97% storage savings), fall back to FAISS
  # - native-leann: Use NativeLEANN only (requires `pip install leann`)
  # - leann: Use LEANNIndex (cosine similarity, no external dependency)
  # - faiss: Use FAISS only (IndexFlatL2 + IndexIDMap2, supports incremental updates)
  vector_index: auto

  # Graph backend for PageRank computation
  # Options: "auto" | "igraph" | "networkx"
  # - auto: Try igraph first, fall back to NetworkX if unavailable
  # - igraph: Use igraph only (C++ backend, <1s for 10k files)
  # - networkx: Use NetworkX only (pure Python, <10s for 10k files)
  graph: igraph

  # Embeddings backend for vector generation
  # Options: "auto" | "local" | "api"
  # - auto: Try local first, fall back to API on OOM
  # - local: Use sentence-transformers only (requires GPU or sufficient RAM)
  # - api: Use OpenAI API only (requires OPENAI_API_KEY env var)
  embeddings: auto

# ==============================================================================
# EMBEDDINGS CONFIGURATION
# ==============================================================================

embeddings:
  # Sentence-transformers model for local embeddings
  # Popular options:
  #   - all-MiniLM-L6-v2: Fast, 384 dimensions (default)
  #   - all-mpnet-base-v2: Better quality, 768 dimensions
  #   - multi-qa-mpnet-base-dot-v1: Optimized for Q&A
  model: all-MiniLM-L6-v2

  # Device for local embeddings computation
  # Options: "cpu" | "cuda" | "mps"
  # - cpu: Use CPU (slower but works everywhere)
  # - cuda: Use NVIDIA GPU (requires CUDA)
  # - mps: Use Apple Silicon GPU (macOS only)
  device: cpu

  # Batch size for embedding generation
  # Larger values are faster but use more memory
  # Reduce if you encounter OOM errors
  # Recommended values:
  #   - CPU: 16-32
  #   - GPU: 64-128
  batch_size: 32

  # API provider for fallback embeddings
  # Options: "openai"
  # Future: "cohere", "anthropic", "huggingface"
  api_provider: openai

  # Environment variable name containing API key
  # Set this environment variable before running ws-ctx-engine
  # Example: export OPENAI_API_KEY="sk-..."
  api_key_env: OPENAI_API_KEY

# ==============================================================================
# LEANN TUNING
# ==============================================================================

leann:
  # recompute_embeddings controls the LEANN storage/speed trade-off:
  #   true  (default) — prune embeddings from index (~60% smaller) but
  #                     recompute ALL doc embeddings on every query (~11s).
  #   false           — store embeddings in index (~20ms warm-path) but
  #                     larger index file.
  # NOTE: recompute_embeddings: false has a known passage-ID bug in LEANN
  # 0.3.x. Keep as true until a fixed version is released.
  recompute_embeddings: true

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================

performance:
  # Not yet active — reserved for future parallel processing.
  # max_workers: 4

  # Cache embeddings to disk so unchanged files are not re-embedded on the
  # next indexing run. Persists vectors to .ws-ctx-engine/embeddings.npy.
  # Set to false to disable and always recompute embeddings (deterministic builds).
  cache_embeddings: true

  # Enable incremental indexing via --incremental flag.
  # When true, only changed/deleted files are re-indexed.
  # Set to false to always perform full rebuilds.
  incremental_index: true

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================

# NOT YET IMPLEMENTED — logging config fields are parsed but not applied.
# Use --quiet / --no-quiet CLI flags to control log verbosity instead.
# logging:
#   console_level: INFO
#   file_level: DEBUG
#   verbose: false

# ==============================================================================
# ADVANCED OPTIONS
# ==============================================================================

# NOT YET IMPLEMENTED — advanced fields are accepted but silently ignored.
# advanced:
#   pagerank_damping: 0.85         # NOT YET IMPLEMENTED
#   changed_file_boost: 2.0        # NOT YET IMPLEMENTED
#   pagerank_max_iterations: 100   # NOT YET IMPLEMENTED
#   pagerank_tolerance: 0.0001     # NOT YET IMPLEMENTED
#   min_file_size: 0               # NOT YET IMPLEMENTED
#   max_file_size: 1000000         # NOT YET IMPLEMENTED
#   validate_roundtrip: false      # NOT YET IMPLEMENTED

# ==============================================================================
# EXAMPLE CONFIGURATIONS
# ==============================================================================

# Example 1: PR Review Workflow
# Optimize for reviewing changed files and their dependencies
# 
# semantic_weight: 0.4
# pagerank_weight: 0.6
# changed_file_boost: 3.0
# format: zip

# Example 2: Bug Investigation
# Optimize for semantic search with natural language queries
# 
# semantic_weight: 0.8
# pagerank_weight: 0.2
# format: xml
# token_budget: 50000

# Example 3: Documentation Generation
# Optimize for core API files and public interfaces
# 
# semantic_weight: 0.5
# pagerank_weight: 0.5
# include_patterns:
#   - "**/api/**/*.py"
#   - "**/models/**/*.py"
#   - "**/schemas/**/*.py"

# Example 4: Minimal Dependencies (No Optional Backends)
# Use only core dependencies with fallback algorithms
# 
# backends:
#   vector_index: faiss
#   graph: networkx
#   embeddings: api

# Example 5: Maximum Performance (All Primary Backends)
# Use all primary backends for optimal speed
# 
# backends:
#   vector_index: leann
#   graph: igraph
#   embeddings: local
# embeddings:
#   device: cuda
#   batch_size: 128
